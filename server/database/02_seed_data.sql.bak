/* =============================================================
   FILE: data/13_variant_attributes.sql
   ============================================================= */

/* ============================================================
   VARIANT ATTRIBUTES DATA - AISTHEA
   Maps each ProductVariant to Mau sac + Kich thuoc.
   ============================================================ */
USE AISTHEA;
GO

-- 1. Fix IsDefault: mark first variant per product as default
UPDATE [ProductVariants] SET [IsDefault] = 0 WHERE [IsDeleted] = 0;
GO

UPDATE pv SET pv.[IsDefault] = 1
FROM [ProductVariants] pv
INNER JOIN (
    SELECT ProductId, MIN(VariantId) AS FirstVariantId
    FROM [ProductVariants] WHERE IsDeleted = 0 GROUP BY ProductId
) AS fv ON pv.VariantId = fv.FirstVariantId;
GO
PRINT 'IsDefault fixed';
GO

-- 2. Clear and re-insert VariantAttributes
IF OBJECT_ID('dbo.VariantAttributes','U') IS NOT NULL DELETE FROM [VariantAttributes];
GO

