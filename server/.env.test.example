# Minimal test env for Jest / CI
NODE_ENV=test
CI=true

# Required by env validation
DATABASE_URL="mysql://ci-user:ci-pass@127.0.0.1:3306/aisthea_ci"
JWT_SECRET="12345678901234567890123456789012"
REFRESH_SECRET="abcdefghijklmnopqrstuvwxyz123456"
SESSION_SECRET="12345678901234567890123456789012"

# Safe local URLs for tests
CLIENT_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"
SERVER_URL="http://localhost:5000"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"
TRUST_PROXY=false
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Optional integrations with safe placeholders
VNP_TMN_CODE=TESTTMN
VNP_HASH_SECRET="12345678901234567890123456789012"
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNP_API="https://sandbox.vnpayment.vn/merchant_webapi/api/transaction"
VNP_RETURN_URL="http://localhost:3000/vnpay-return"

CLOUDINARY_CLOUD_NAME=demo-cloud
CLOUDINARY_API_KEY=demo-api-key
CLOUDINARY_API_SECRET=demo-api-secret

MOCK_AI=true
