generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId       Int         @id @default(autoincrement()) @map("UserId")
  email        String      @unique(map: "UQ__Users__A9D10534540118E1") @map("Email") @db.VarChar(100)
  passwordHash String?     @map("PasswordHash") @db.VarChar(255)
  fullName     String      @map("FullName") @db.VarChar(100)
  phone        String?     @map("Phone") @db.VarChar(20)
  avatarUrl    String?     @map("AvatarUrl") @db.VarChar(1000)
  googleId     String?     @unique(map: "UQ_Users_GoogleId") @map("GoogleId") @db.VarChar(255)
  status       String      @default("Pending") @map("Status") @db.VarChar(20)
  createdAt    DateTime?   @default(now()) @map("CreatedAt")
  updatedAt    DateTime?   @default(now()) @updatedAt @map("UpdatedAt")
  addresses    Address[]
  orders       Order[]
  reviews      Review[]
  userLogins   UserLogin[]
  userRoles    UserRole[]
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  inventoryLogs InventoryLog[]
  orderReturns  OrderReturn[]
  returnRequests ReturnRequest[]
  cart          Cart?        // 1-to-1: mỗi user có tối đa một giỏ hàng
  stockMovements StockMovement[]
  goodsReceipts  GoodsReceipt[]
  returnRequestStatusLogs ReturnRequestStatusLog[] @relation("ReturnRequestStatusChangedBy")
  processedRefundTransactions RefundTransaction[] @relation("RefundTransactionProcessedBy")
  customerBankAccounts CustomerBankAccount[]
  refundBenefits RefundBenefit[]
  uploadedRefundPayoutProofs RefundPayoutProof[] @relation("RefundPayoutProofUploadedBy")

  @@index([email, status], map: "IX_Users_Email_Status")
  @@index([phone], map: "IX_Users_Phone")
  @@index([status], map: "IX_Users_Status")
  @@map("Users")
}

model EmailVerificationToken {
  tokenId   Int      @id @default(autoincrement()) @map("TokenId")
  userId    Int      @map("UserId")
  token     String   @unique @map("Token") @db.VarChar(255)
  expiresAt DateTime @map("ExpiresAt")
  createdAt DateTime @default(now()) @map("CreatedAt")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId], map: "IX_EmailVerificationTokens_UserId")
  @@map("EmailVerificationTokens")
}

model PasswordResetToken {
  tokenId   Int      @id @default(autoincrement()) @map("TokenId")
  userId    Int      @map("UserId")
  token     String   @unique @map("Token") @db.VarChar(255)
  expiresAt DateTime @map("ExpiresAt")
  createdAt DateTime @default(now()) @map("CreatedAt")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId], map: "IX_PasswordResetTokens_UserId")
  @@map("PasswordResetTokens")
}

model Role {
  roleId          Int              @id @default(autoincrement()) @map("RoleId")
  roleName        String           @unique(map: "UQ__Roles__8A2B6160E320F027") @map("RoleName") @db.VarChar(50)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("Roles")
}

model UserRole {
  userId Int  @map("UserId")
  roleId Int  @map("RoleId")
  role   Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserRoles_Roles")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserRoles_Users")

  @@id([userId, roleId])
  @@map("UserRoles")
}

// ─── RBAC: Permissions & Role-Permission join ────────────────────────────────

model Permission {
  permissionId    Int              @id @default(autoincrement()) @map("PermissionId")
  code            String           @unique @map("Code") @db.VarChar(100)        // e.g. 'CREATE_PRODUCT'
  module          String           @map("Module") @db.VarChar(50)               // e.g. 'PRODUCT'
  description     String           @map("Description") @db.VarChar(255)
  rolePermissions RolePermission[]

  @@index([module], map: "IX_Permissions_Module")
  @@map("Permissions")
}

model RolePermission {
  roleId       Int        @map("RoleId")
  permissionId Int        @map("PermissionId")
  role         Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: NoAction, map: "FK_RolePermissions_Roles")
  permission   Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade, onUpdate: NoAction, map: "FK_RolePermissions_Permissions")

  @@id([roleId, permissionId])
  @@map("RolePermissions")
}

model UserLogin {
  loginProvider       String    @map("LoginProvider") @db.VarChar(50)
  providerKey         String    @map("ProviderKey") @db.VarChar(128)
  providerDisplayName String?   @map("ProviderDisplayName") @db.VarChar(100)
  userId              Int       @map("UserId")
  accessToken         String?   @map("AccessToken") @db.LongText
  refreshToken        String?   @map("RefreshToken") @db.LongText
  tokenExpiry         DateTime? @map("TokenExpiry")
  createdAt           DateTime? @default(now()) @map("CreatedAt")
  updatedAt           DateTime? @default(now()) @updatedAt @map("UpdatedAt")
  user                User      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserLogins_Users")

  @@id([loginProvider, providerKey])
  @@index([userId], map: "IX_UserLogins_UserId")
  @@map("UserLogins")
}

model Address {
  addressId     Int      @id @default(autoincrement()) @map("AddressId")
  userId        Int      @map("UserId")
  recipientName String   @map("RecipientName") @db.VarChar(100)
  phone         String   @map("Phone") @db.VarChar(20)
  addressLine   String   @map("AddressLine") @db.VarChar(255)
  city          String   @map("City") @db.VarChar(50)
  district      String?  @map("District") @db.VarChar(50)
  ward          String?  @map("Ward") @db.VarChar(50)
  isDefault     Boolean? @default(false) @map("IsDefault")
  user          User     @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Addresses_Users")

  @@index([userId, isDefault], map: "IX_Addresses_UserId_IsDefault")
  @@map("Addresses")
}

model Category {
  categoryId  Int        @id @default(autoincrement()) @map("CategoryId")
  parentId    Int?       @map("ParentId")
  name        String     @map("Name") @db.VarChar(100)
  slug        String     @unique(map: "UQ__Categori__BC7B5FB636C79C65") @map("Slug") @db.VarChar(100)
  description String?    @map("Description") @db.VarChar(255)
  imageUrl    String?    @map("ImageUrl") @db.VarChar(1000)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [categoryId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Categories_Parent")
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([parentId], map: "IX_Categories_ParentId")
  @@map("Categories")
}

model Brand {
  brandId     Int       @id @default(autoincrement()) @map("BrandId")
  name        String    @unique(map: "UQ__Brands__737584F6CEC21B5F") @map("Name") @db.VarChar(100)
  description String?   @map("Description") @db.VarChar(255)
  products    Product[]

  @@map("Brands")
}

model Product {
  productId   Int              @id @default(autoincrement()) @map("ProductId")
  categoryId  Int              @map("CategoryId")
  brandId     Int?             @map("BrandId")
  name        String           @map("Name") @db.VarChar(200)
  slug        String           @unique(map: "UQ__Products__BC7B5FB63F5A8249") @map("Slug") @db.VarChar(200)
  description String?          @map("Description") @db.LongText
  basePrice   Decimal          @map("BasePrice") @db.Decimal(18, 2)
  status      String?          @default("Active") @map("Status") @db.VarChar(20)
  isDeleted   Boolean?         @default(false) @map("IsDeleted")
  deletedAt   DateTime?        @map("DeletedAt")
  createdAt   DateTime?        @default(now()) @map("CreatedAt")
  images      ProductImage[]
  brand       Brand?           @relation(fields: [brandId], references: [brandId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Products_Brands")
  category    Category         @relation(fields: [categoryId], references: [categoryId], onUpdate: NoAction, map: "FK_Products_Categories")
  variants    ProductVariant[]
  reviews     Review[]

  @@index([basePrice], map: "IX_Products_BasePrice")
  @@index([brandId], map: "IX_Products_BrandId")
  @@index([categoryId], map: "IX_Products_CategoryId")
  @@index([name], map: "IX_Products_Name")
  @@index([status], map: "IX_Products_Status")
  @@map("Products")
}

model ProductVariant {
  variantId         Int                @id @default(autoincrement()) @map("VariantId")
  productId         Int                @map("ProductId")
  sku               String             @unique(map: "UQ__ProductV__CA1ECF0D48746AB3") @map("SKU") @db.VarChar(50)
  price             Decimal            @map("Price") @db.Decimal(18, 2)
  stockQuantity     Int                @default(0) @map("StockQuantity")
  isDefault         Boolean?           @default(false) @map("IsDefault")
  isDeleted         Boolean?           @default(false) @map("IsDeleted")
  deletedAt         DateTime?          @map("DeletedAt")
  cartItems         CartItem[]
  orderItems        OrderItem[]
  images            ProductImage[]
  product           Product            @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ProductVariants_Products")
  variantAttributes VariantAttribute[]
  inventoryLogs      InventoryLog[]
  purchaseOrderItems PurchaseOrderItem[]
  inventorySnapshot  Inventory?
  stockMovements     StockMovement[]
  goodsReceiptItems  GoodsReceiptItem[]

  @@index([productId], map: "IX_ProductVariants_ProductId")
  @@index([stockQuantity], map: "IX_ProductVariants_StockQuantity")
  @@map("ProductVariants")
}

model Attribute {
  attributeId Int              @id @default(autoincrement()) @map("AttributeId")
  name        String           @unique(map: "UQ__Attribut__737584F6C9E6DEE8") @map("Name") @db.VarChar(50)
  values      AttributeValue[]

  @@map("Attributes")
}

model AttributeValue {
  valueId           Int                @id @default(autoincrement()) @map("ValueId")
  attributeId       Int                @map("AttributeId")
  value             String             @map("Value") @db.VarChar(50)
  attribute         Attribute          @relation(fields: [attributeId], references: [attributeId], onDelete: Cascade, onUpdate: NoAction, map: "FK_AttributeValues_Attributes")
  variantAttributes VariantAttribute[]

  @@map("AttributeValues")
}

model VariantAttribute {
  variantId Int            @map("VariantId")
  valueId   Int            @map("ValueId")
  value     AttributeValue @relation(fields: [valueId], references: [valueId], onDelete: Cascade, onUpdate: NoAction, map: "FK_VariantAttributes_Values")
  variant   ProductVariant @relation(fields: [variantId], references: [variantId], onDelete: Cascade, onUpdate: NoAction, map: "FK_VariantAttributes_Variants")

  @@id([variantId, valueId])
  @@index([valueId], map: "IX_VariantAttributes_ValueId")
  @@map("VariantAttributes")
}

model ProductImage {
  imageId      Int             @id @default(autoincrement()) @map("ImageId")
  productId    Int             @map("ProductId")
  variantId    Int?            @map("VariantId")
  imageUrl     String          @map("ImageUrl") @db.VarChar(1000)
  thumbnailUrl String?         @map("ThumbnailUrl") @db.VarChar(1000)
  isPrimary    Boolean?        @default(false) @map("IsPrimary")
  product      Product         @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ProductImages_Products")
  variant      ProductVariant? @relation(fields: [variantId], references: [variantId], onDelete: NoAction, onUpdate: NoAction, map: "FK_ProductImages_Variants")

  @@map("ProductImages")
}

model Cart {
  cartId    Int        @id @default(autoincrement()) @map("CartId")
  userId    Int?       @unique(map: "UQ_Carts_UserId") @map("UserId")   // 1-to-1 với User
  sessionId String?    @map("SessionId") @db.VarChar(100)
  createdAt DateTime?  @default(now()) @map("CreatedAt")
  updatedAt DateTime?  @default(now()) @updatedAt @map("UpdatedAt")
  user      User?      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Carts_Users")
  items     CartItem[]

  @@map("Carts")
}

model CartItem {
  cartItemId Int            @id @default(autoincrement()) @map("CartItemId")
  cartId     Int            @map("CartId")
  variantId  Int            @map("VariantId")
  quantity   Int            @map("Quantity")
  addedAt    DateTime?      @default(now()) @map("AddedAt")
  cart       Cart           @relation(fields: [cartId], references: [cartId], onDelete: Cascade, onUpdate: NoAction, map: "FK_CartItems_Carts")
  variant    ProductVariant @relation(fields: [variantId], references: [variantId], onDelete: Cascade, onUpdate: NoAction, map: "FK_CartItems_Variants")

  @@unique([cartId, variantId], map: "UQ_CartItems_Cart_Variant") // ngăn trùng lặp sản phẩm trong giỏ
  @@map("CartItems")
}

// ─── Order Status FSM strings ─────────────────────────────────────────────────
// Valid status values: Pending | Processing | Shipping | Delivered | Cancelled
//                     Return_Requested | Returned

model Order {
  orderId               Int         @id @default(autoincrement()) @map("OrderId")
  userId                Int?        @map("UserId")
  orderNumber           String      @unique(map: "UQ__Orders__CAC5E7434BE02B58") @map("OrderNumber") @db.VarChar(50)
  customerName          String      @map("CustomerName") @db.VarChar(100)
  customerEmail         String?     @map("CustomerEmail") @db.VarChar(100)
  customerPhone         String      @map("CustomerPhone") @db.VarChar(20)
  shippingCity          String      @map("ShippingCity") @db.VarChar(50)
  shippingDistrict      String      @map("ShippingDistrict") @db.VarChar(50)
  shippingWard          String?     @map("ShippingWard") @db.VarChar(50)
  shippingAddressDetail String      @map("ShippingAddressDetail") @db.VarChar(200)
  shippingFee           Decimal     @default(0) @map("ShippingFee") @db.Decimal(18, 2)
  shippingMethod        String      @default("STANDARD") @map("ShippingMethod") @db.VarChar(20)
  shippingCityCode      String?     @map("ShippingCityCode") @db.VarChar(10)
  totalAmount           Decimal     @map("TotalAmount") @db.Decimal(18, 2)
  discountAmount        Decimal?    @default(0) @map("DiscountAmount") @db.Decimal(18, 2)
  couponId              Int?        @map("CouponId")
  status                String?     @default("Pending") @map("Status") @db.VarChar(20)
  paymentMethod         String?     @default("COD") @map("PaymentMethod") @db.VarChar(50)
  createdAt             DateTime?   @default(now()) @map("CreatedAt")
  updatedAt             DateTime?   @default(now()) @updatedAt @map("UpdatedAt")
  items                 OrderItem[]
  user                  User?       @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Orders_Users")
  coupon                Coupon?     @relation(fields: [couponId], references: [couponId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Orders_Coupons")
  payments              Payment[]
  statusHistory         OrderStatusHistory[]
  shipment              Shipment?
  note                  String?     @map("Note") @db.VarChar(500)
  inventoryLogs         InventoryLog[]
  orderReturn           OrderReturn?
  refunds               Refund[]
  returnRequests        ReturnRequest[]
  refundBenefits        RefundBenefit[]

  @@index([createdAt], map: "IX_Orders_CreatedAt")
  @@index([status], map: "IX_Orders_Status")
  @@index([userId], map: "IX_Orders_UserId")
  @@map("Orders")
}

model OrderStatusHistory {
  orderStatusHistoryId Int      @id @default(autoincrement()) @map("OrderStatusHistoryId")
  orderId              Int      @map("OrderId")
  oldStatus            String?  @map("OldStatus") @db.VarChar(20)
  status               String   @map("Status") @db.VarChar(20)
  changedBy            Int?     @map("ChangedBy")
  note                 String?  @map("Note") @db.VarChar(500)
  changedAt            DateTime @default(now()) @map("ChangedAt")
  order                Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_OrderStatusHistory_Orders")

  @@index([orderId], map: "IX_OrderStatusHistory_OrderId")
  @@index([orderId, changedAt], map: "IX_OrderStatusHistory_OrderId_ChangedAt")
  @@map("OrderStatusHistory")
}

model Shipment {
  shipmentId          Int       @id @default(autoincrement()) @map("ShipmentId")
  orderId             Int       @unique @map("OrderId")
  shippingMode        String    @default("manual") @map("ShippingMode") @db.VarChar(20)
  provider            String?   @map("Provider") @db.VarChar(50)
  providerOrderCode   String?   @map("ProviderOrderCode") @db.VarChar(100)
  providerStatus      String?   @map("ProviderStatus") @db.VarChar(50)
  carrier             String?   @map("Carrier") @db.VarChar(100)
  trackingNumber      String?   @map("TrackingNumber") @db.VarChar(100)
  eta                 DateTime? @map("Eta")
  lastKnownLocation   String?   @map("LastKnownLocation") @db.VarChar(255)
  deliveryProofImages String    @default("[]") @map("DeliveryProofImages") @db.LongText
  deliveryProofReviewed Boolean @default(false) @map("DeliveryProofReviewed")
  createdAt           DateTime  @default(now()) @map("CreatedAt")
  updatedAt           DateTime  @default(now()) @updatedAt @map("UpdatedAt")
  order               Order     @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([trackingNumber], map: "IX_Shipments_TrackingNumber")
  @@index([providerOrderCode], map: "IX_Shipments_ProviderOrderCode")
  @@map("Shipments")
}

model OrderItem {
  orderItemId              Int             @id @default(autoincrement()) @map("OrderItemId")
  orderId                  Int             @map("OrderId")
  variantId                Int?            @map("VariantId")
  productName              String          @map("ProductName") @db.VarChar(200)
  sku                      String          @map("SKU") @db.VarChar(50)
  variantName              String          @map("VariantName") @db.VarChar(200)
  unitPrice                Decimal         @map("UnitPrice") @db.Decimal(18, 2)
  quantity                 Int             @map("Quantity")
  grossItemAmount          Decimal         @default(0) @map("GrossItemAmount") @db.Decimal(18, 2)
  allocatedDiscountAmount  Decimal         @default(0) @map("AllocatedDiscountAmount") @db.Decimal(18, 2)
  netItemPaidAmount        Decimal         @default(0) @map("NetItemPaidAmount") @db.Decimal(18, 2)
  order                    Order           @relation(fields: [orderId], references: [orderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_OrderItems_Orders")
  variant                  ProductVariant? @relation(fields: [variantId], references: [variantId], onUpdate: NoAction, map: "FK_OrderItems_Variants")
  review                   Review?         // One-to-one: each purchased item can have at most one review
  returnRequestItems ReturnRequestItem[]

  @@index([orderId], map: "IX_OrderItems_OrderId")
  @@index([variantId], map: "IX_OrderItems_VariantId")
  @@map("OrderItems")
}

model Payment {
  paymentId       Int       @id @default(autoincrement()) @map("PaymentId")
  orderId         Int       @map("OrderId")
  paymentMethod   String    @map("PaymentMethod") @db.VarChar(50)
  amount          Decimal   @map("Amount") @db.Decimal(18, 2)
  transactionCode String?   @map("TransactionCode") @db.VarChar(100)
  status          String    @default("Pending") @map("Status") @db.VarChar(20)
  paymentDate     DateTime? @default(now()) @map("PaymentDate")
  note            String?   @map("Note") @db.VarChar(500)
  order           Order     @relation(fields: [orderId], references: [orderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Payments_Orders")
  refunds         Refund[]

  @@index([orderId], map: "IX_Payments_OrderId")
  @@map("Payments")
}

model Review {
  reviewId    Int        @id @default(autoincrement()) @map("ReviewId")
  productId   Int        @map("ProductId")
  userId      Int        @map("UserId")
  orderItemId Int?       @unique(map: "UQ_Reviews_OrderItemId") @map("OrderItemId") // CRITICAL: one review per purchased item
  rating      Int?       @map("Rating")
  comment     String?    @map("Comment") @db.VarChar(1000)
  images      String?    @default("[]") @map("Images") @db.LongText // JSON array of Cloudinary URLs
  createdAt   DateTime?  @default(now()) @map("CreatedAt")
  product     Product    @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Reviews_Products")
  user        User       @relation(fields: [userId], references: [userId], onUpdate: NoAction, map: "FK_Reviews_Users")
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [orderItemId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Reviews_OrderItems")

  @@index([productId], map: "IX_Reviews_ProductId")
  @@index([userId], map: "IX_Reviews_UserId")
  @@map("Reviews")
}

// ─── Inventory Audit Log ──────────────────────────────────────────────────────
// Reason values: CHECKOUT | PURCHASE_RECEIPT | RETURN_RESTORE | MANUAL_ADJUST

model InventoryLog {
  logId          Int      @id @default(autoincrement()) @map("LogId")
  variantId      Int      @map("VariantId")
  orderId        Int?     @map("OrderId")
  userId         Int?     @map("UserId")
  changeQuantity Int      @map("ChangeQuantity") // negative for deductions, positive for restocks
  previousStock  Int      @map("PreviousStock")
  newStock       Int      @map("NewStock")
  reason         String   @map("Reason") @db.VarChar(30)
  note           String?  @map("Note") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("CreatedAt")

  variant ProductVariant @relation(fields: [variantId], references: [variantId], onDelete: Cascade, onUpdate: NoAction, map: "FK_InventoryLogs_Variants")
  order   Order?         @relation(fields: [orderId], references: [orderId], onDelete: SetNull, onUpdate: NoAction, map: "FK_InventoryLogs_Orders")
  user    User?          @relation(fields: [userId], references: [userId], onDelete: SetNull, onUpdate: NoAction, map: "FK_InventoryLogs_Users")

  @@index([variantId], map: "IX_InventoryLogs_VariantId")
  @@index([orderId],   map: "IX_InventoryLogs_OrderId")
  @@map("InventoryLogs")
}

// ─── Return & Refund ──────────────────────────────────────────────────────────
// OrderReturn.status values: PENDING_APPROVAL | APPROVED | REJECTED | COMPLETED

model OrderReturn {
  returnId    Int      @id @default(autoincrement()) @map("ReturnId")
  orderId     Int      @unique @map("OrderId")                           // One return per order
  userId      Int?     @map("UserId")                                    // Customer who requested
  reason      String   @map("Reason") @db.VarChar(500)
  proofImages String   @default("[]") @map("ProofImages") @db.LongText // JSON array of Cloudinary URLs
  status      String   @default("PENDING_APPROVAL") @map("Status") @db.VarChar(30)
  adminNote   String?  @map("AdminNote") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("CreatedAt")
  updatedAt   DateTime @default(now()) @updatedAt @map("UpdatedAt")

  order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_OrderReturns_Orders")
  user  User? @relation(fields: [userId], references: [userId], onDelete: SetNull, onUpdate: NoAction, map: "FK_OrderReturns_Users")

  @@index([status],  map: "IX_OrderReturns_Status")
  @@index([userId],  map: "IX_OrderReturns_UserId")
  @@map("OrderReturns")
}

model ReturnRequest {
  returnRequestId   Int                       @id @default(autoincrement()) @map("ReturnRequestId")
  orderId           Int                       @map("OrderId")
  userId            Int                       @map("UserId")
  reason            String                    @map("Reason") @db.VarChar(500)
  note              String?                   @map("Note") @db.VarChar(1000)
  deliveredAt       DateTime?                 @map("DeliveredAt")
  totalRefundAmount Decimal                   @default(0) @map("TotalRefundAmount") @db.Decimal(18, 2)
  status            String                    @default("REQUESTED") @map("Status") @db.VarChar(50)
  refundStatus      String                    @default("NOT_APPLICABLE") @map("RefundStatus") @db.VarChar(50)
  financeNote       String?                   @map("FinanceNote") @db.VarChar(1000)
  bankInfoRequestedAt DateTime?              @map("BankInfoRequestedAt")
  bankInfoSubmittedAt DateTime?              @map("BankInfoSubmittedAt")
  refundCompletedAt  DateTime?                @map("RefundCompletedAt")
  createdAt         DateTime                  @default(now()) @map("CreatedAt")
  updatedAt         DateTime                  @default(now()) @updatedAt @map("UpdatedAt")
  order             Order                     @relation(fields: [orderId], references: [orderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ReturnRequests_Orders")
  user              User                      @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "FK_ReturnRequests_Users")
  items             ReturnRequestItem[]
  attachments       ReturnRequestAttachment[]
  statusLogs        ReturnRequestStatusLog[]
  refundTransactions RefundTransaction[]
  refundBankSnapshots RefundBankSnapshot[]
  refundPayoutProofs RefundPayoutProof[]
  refundBenefits    RefundBenefit[]

  @@index([orderId], map: "IX_ReturnRequests_OrderId")
  @@index([status], map: "IX_ReturnRequests_Status")
  @@index([userId], map: "IX_ReturnRequests_UserId")
  @@index([createdAt], map: "IX_ReturnRequests_CreatedAt")
  @@map("ReturnRequests")
}

model ReturnRequestItem {
  returnRequestItemId Int           @id @default(autoincrement()) @map("ReturnRequestItemId")
  returnRequestId     Int           @map("ReturnRequestId")
  orderItemId         Int           @map("OrderItemId")
  quantity            Int           @map("Quantity")
  unitPrice           Decimal       @map("UnitPrice") @db.Decimal(18, 2)
  reason              String        @map("Reason") @db.VarChar(500)
  reasonText          String?       @map("ReasonText") @db.VarChar(200)
  createdAt           DateTime      @default(now()) @map("CreatedAt")
  returnRequest       ReturnRequest @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ReturnRequestItems_ReturnRequests")
  orderItem           OrderItem     @relation(fields: [orderItemId], references: [orderItemId], onDelete: NoAction, onUpdate: NoAction, map: "FK_ReturnRequestItems_OrderItems")
  attachments         ReturnRequestAttachment[]

  @@index([orderItemId], map: "IX_ReturnRequestItems_OrderItemId")
  @@index([returnRequestId], map: "IX_ReturnRequestItems_ReturnRequestId")
  @@map("ReturnRequestItems")
}

model ReturnRequestAttachment {
  attachmentId         Int                @id @default(autoincrement()) @map("AttachmentId")
  returnRequestId      Int                @map("ReturnRequestId")
  returnRequestItemId  Int?               @map("ReturnRequestItemId")
  fileUrl              String             @map("FileUrl") @db.VarChar(1000)
  createdAt            DateTime           @default(now()) @map("CreatedAt")
  returnRequest        ReturnRequest      @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ReturnRequestAttachments_ReturnRequests")
  returnRequestItem    ReturnRequestItem? @relation(fields: [returnRequestItemId], references: [returnRequestItemId], onDelete: NoAction, onUpdate: NoAction, map: "FK_ReturnRequestAttachments_ReturnRequestItems")

  @@index([returnRequestId], map: "IX_ReturnRequestAttachments_ReturnRequestId")
  @@index([returnRequestItemId], map: "IX_ReturnRequestAttachments_ReturnRequestItemId")
  @@map("ReturnRequestAttachments")
}

model ReturnRequestStatusLog {
  returnRequestStatusLogId Int           @id @default(autoincrement()) @map("ReturnRequestStatusLogId")
  returnRequestId          Int           @map("ReturnRequestId")
  fromStatus               String?       @map("FromStatus") @db.VarChar(50)
  toStatus                 String        @map("ToStatus") @db.VarChar(50)
  changedBy                Int?          @map("ChangedBy")
  comment                  String?       @map("Comment") @db.VarChar(1000)
  createdAt                DateTime      @default(now()) @map("CreatedAt")
  returnRequest            ReturnRequest @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ReturnRequestStatusLogs_ReturnRequests")
  changedByUser            User?         @relation("ReturnRequestStatusChangedBy", fields: [changedBy], references: [userId], onDelete: SetNull, onUpdate: NoAction, map: "FK_ReturnRequestStatusLogs_Users")

  @@index([createdAt], map: "IX_ReturnRequestStatusLogs_CreatedAt")
  @@index([returnRequestId], map: "IX_ReturnRequestStatusLogs_ReturnRequestId")
  @@index([changedBy], map: "IX_ReturnRequestStatusLogs_ChangedBy")
  @@map("ReturnRequestStatusLogs")
}

model RefundTransaction {
  refundTransactionId Int           @id @default(autoincrement()) @map("RefundTransactionId")
  returnRequestId     Int           @map("ReturnRequestId")
  amount              Decimal       @map("Amount") @db.Decimal(18, 2)
  method              String        @map("Method") @db.VarChar(30)
  status              String        @default("PENDING") @map("Status") @db.VarChar(30)
  idempotencyKey      String        @unique(map: "UQ_RefundTransactions_IdempotencyKey") @map("IdempotencyKey") @db.VarChar(100)
  transactionRef      String?       @map("TransactionRef") @db.VarChar(100)
  processedBy         Int?          @map("ProcessedBy")
  createdAt           DateTime      @default(now()) @map("CreatedAt")
  updatedAt           DateTime      @default(now()) @updatedAt @map("UpdatedAt")
  returnRequest       ReturnRequest @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: Cascade, onUpdate: NoAction, map: "FK_RefundTransactions_ReturnRequests")
  processedByUser     User?         @relation("RefundTransactionProcessedBy", fields: [processedBy], references: [userId], onDelete: SetNull, onUpdate: NoAction, map: "FK_RefundTransactions_Users")
  payoutProofs        RefundPayoutProof[]

  @@index([returnRequestId], map: "IX_RefundTransactions_ReturnRequestId")
  @@index([status], map: "IX_RefundTransactions_Status")
  @@index([processedBy], map: "IX_RefundTransactions_ProcessedBy")
  @@map("RefundTransactions")
}

// ─── Coupon & Discount System ─────────────────────────────────────────────────
// type values enforced at application layer: "FIXED_AMOUNT" | "PERCENTAGE"

model Coupon {
  couponId          Int      @id @default(autoincrement()) @map("CouponId")
  code              String   @unique @map("Code") @db.VarChar(50)
  type              String   @map("Type") @db.VarChar(20) // "FIXED_AMOUNT" | "PERCENTAGE"
  value             Decimal  @map("Value") @db.Decimal(18, 2)
  maxDiscountAmount Decimal? @map("MaxDiscountAmount") @db.Decimal(18, 2) // Cap for PERCENTAGE type
  minOrderValue     Decimal  @default(0) @map("MinOrderValue") @db.Decimal(18, 2)
  startDate         DateTime @map("StartDate")
  endDate           DateTime @map("EndDate")
  usageLimit        Int      @map("UsageLimit")
  usedCount         Int      @default(0) @map("UsedCount")
  usagePerUser      Int      @default(1) @map("UsagePerUser")
  isActive          Boolean  @default(true) @map("IsActive")
  isHidden          Boolean  @default(false) @map("IsHidden")
  source            String?  @map("Source") @db.VarChar(30)
  visibleInPublicList Boolean @default(true) @map("VisibleInPublicList")
  createdAt         DateTime @default(now()) @map("CreatedAt")
  updatedAt         DateTime @default(now()) @updatedAt @map("UpdatedAt")
  orders            Order[]
  refundBenefits    RefundBenefit[]

  @@index([isActive], map: "IX_Coupons_IsActive")
  @@index([source], map: "IX_Coupons_Source")
  @@map("Coupons")
}

model CustomerBankAccount {
  bankAccountId   Int      @id @default(autoincrement()) @map("BankAccountId")
  userId          Int      @map("UserId")
  bankName        String   @map("BankName") @db.VarChar(120)
  bankCode        String?  @map("BankCode") @db.VarChar(50)
  accountNumber   String   @map("AccountNumber") @db.VarChar(50)
  accountHolder   String   @map("AccountHolder") @db.VarChar(120)
  qrImageUrl      String?  @map("QrImageUrl") @db.VarChar(1000)
  inputMethod     String   @map("InputMethod") @db.VarChar(20)
  isDefault       Boolean  @default(true) @map("IsDefault")
  isActive        Boolean  @default(true) @map("IsActive")
  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime @default(now()) @updatedAt @map("UpdatedAt")
  user            User     @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "FK_CustomerBankAccounts_Users")
  refundSnapshots RefundBankSnapshot[]

  @@index([userId], map: "IX_CustomerBankAccounts_UserId")
  @@index([userId, isDefault], map: "IX_CustomerBankAccounts_UserId_IsDefault")
  @@index([userId, isDefault, isActive], map: "IX_CustomerBankAccounts_UserId_IsDefault_IsActive")
  @@map("CustomerBankAccounts")
}

model RefundBankSnapshot {
  refundBankSnapshotId Int                  @id @default(autoincrement()) @map("RefundBankSnapshotId")
  returnRequestId      Int                  @map("ReturnRequestId")
  bankAccountId        Int?                 @map("BankAccountId")
  bankName             String               @map("BankName") @db.VarChar(120)
  bankCode             String?              @map("BankCode") @db.VarChar(50)
  accountNumberMasked  String               @map("AccountNumberMasked") @db.VarChar(50)
  accountHolder        String               @map("AccountHolder") @db.VarChar(120)
  qrImageUrl           String?              @map("QrImageUrl") @db.VarChar(1000)
  inputMethod          String               @map("InputMethod") @db.VarChar(20)
  capturedAt           DateTime             @default(now()) @map("CapturedAt")
  returnRequest        ReturnRequest        @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: Cascade, onUpdate: NoAction, map: "FK_RefundBankSnapshots_ReturnRequests")
  bankAccount          CustomerBankAccount? @relation(fields: [bankAccountId], references: [bankAccountId], onDelete: SetNull, onUpdate: NoAction, map: "FK_RefundBankSnapshots_CustomerBankAccounts")

  @@index([returnRequestId], map: "IX_RefundBankSnapshots_ReturnRequestId")
  @@index([returnRequestId, capturedAt], map: "IX_RefundBankSnapshots_ReturnRequestId_CapturedAt")
  @@map("RefundBankSnapshots")
}

model RefundPayoutProof {
  refundPayoutProofId Int                @id @default(autoincrement()) @map("RefundPayoutProofId")
  returnRequestId     Int                @map("ReturnRequestId")
  refundTransactionId Int?               @map("RefundTransactionId")
  uploadedBy          Int                @map("UploadedBy")
  fileUrl             String             @map("FileUrl") @db.VarChar(1000)
  fileName            String?            @map("FileName") @db.VarChar(255)
  mimeType            String?            @map("MimeType") @db.VarChar(100)
  note                String?            @map("Note") @db.VarChar(1000)
  createdAt           DateTime           @default(now()) @map("CreatedAt")
  returnRequest       ReturnRequest      @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: NoAction, onUpdate: NoAction, map: "FK_RefundPayoutProofs_ReturnRequests")
  refundTransaction   RefundTransaction? @relation(fields: [refundTransactionId], references: [refundTransactionId], onDelete: SetNull, onUpdate: NoAction, map: "FK_RefundPayoutProofs_RefundTransactions")
  uploadedByUser      User               @relation("RefundPayoutProofUploadedBy", fields: [uploadedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "FK_RefundPayoutProofs_Users")

  @@index([returnRequestId], map: "IX_RefundPayoutProofs_ReturnRequestId")
  @@index([returnRequestId, createdAt], map: "IX_RefundPayoutProofs_ReturnRequestId_CreatedAt")
  @@map("RefundPayoutProofs")
}

model RefundBenefit {
  refundBenefitId    Int          @id @default(autoincrement()) @map("RefundBenefitId")
  returnRequestId    Int          @unique(map: "UQ_RefundBenefits_ReturnRequestId") @map("ReturnRequestId")
  orderId            Int          @map("OrderId")
  userId             Int          @map("UserId")
  benefitType        String       @map("BenefitType") @db.VarChar(20)
  percentValue       Decimal?     @map("PercentValue") @db.Decimal(5, 2)
  maxDiscountAmount  Decimal?     @map("MaxDiscountAmount") @db.Decimal(18, 2)
  minOrderValue      Decimal      @default(0) @map("MinOrderValue") @db.Decimal(18, 2)
  couponId           Int?         @map("CouponId")
  status             String       @map("Status") @db.VarChar(20)
  validFrom          DateTime     @map("ValidFrom")
  validUntil         DateTime     @map("ValidUntil")
  issuedAt           DateTime?    @map("IssuedAt")
  usedAt             DateTime?    @map("UsedAt")
  ruleVersion        String       @map("RuleVersion") @db.VarChar(30)
  source             String       @default("REFUND") @map("Source") @db.VarChar(30)
  metadataJson       String?      @map("MetadataJson") @db.LongText
  returnRequest      ReturnRequest @relation(fields: [returnRequestId], references: [returnRequestId], onDelete: NoAction, onUpdate: NoAction, map: "FK_RefundBenefits_ReturnRequests")
  order              Order        @relation(fields: [orderId], references: [orderId], onDelete: NoAction, onUpdate: NoAction, map: "FK_RefundBenefits_Orders")
  user               User         @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "FK_RefundBenefits_Users")
  coupon             Coupon?      @relation(fields: [couponId], references: [couponId], onDelete: SetNull, onUpdate: NoAction, map: "FK_RefundBenefits_Coupons")

  @@index([userId, status, validUntil], map: "IX_RefundBenefits_UserId_Status_ValidUntil")
  @@map("RefundBenefits")
}

// ─── Financial Refund Ledger ──────────────────────────────────────────────────
// type:   FULL | PARTIAL
// method: ORIGINAL_GATEWAY | BANK_TRANSFER | STORE_WALLET
// status: PENDING | PROCESSING | SUCCESS | FAILED

model Refund {
  refundId             Int      @id @default(autoincrement()) @map("RefundId")
  orderId              Int      @map("OrderId")
  paymentId            Int?     @map("PaymentId")
  amount               Decimal  @map("Amount") @db.Decimal(18, 2)
  type                 String   @map("Type") @db.VarChar(10)
  method               String   @map("Method") @db.VarChar(25)
  status               String   @default("PENDING") @map("Status") @db.VarChar(15)
  gatewayTransactionId String?  @map("GatewayTransactionId") @db.VarChar(100)
  reason               String   @map("Reason") @db.VarChar(500)
  gatewayError         String?  @map("GatewayError") @db.VarChar(500)
  createdBy            Int?     @map("CreatedBy")
  createdAt            DateTime @default(now()) @map("CreatedAt")
  updatedAt            DateTime @default(now()) @updatedAt @map("UpdatedAt")

  order   Order    @relation(fields: [orderId],   references: [orderId],   onDelete: Cascade, onUpdate: NoAction, map: "FK_Refunds_Orders")
  payment Payment? @relation(fields: [paymentId], references: [paymentId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Refunds_Payments")

  @@index([orderId],  map: "IX_Refunds_OrderId")
  @@index([status],   map: "IX_Refunds_Status")
  @@map("Refunds")
}

// ─── Warehouse & Multi-location Inventory ────────────────────────────────────

model PurchaseOrder {
  purchaseOrderId     Int                 @id @default(autoincrement()) @map("PurchaseOrderId")
  purchaseOrderNumber String              @unique(map: "UQ_PurchaseOrders_Number") @map("PurchaseOrderNumber") @db.VarChar(50)
  supplier            String              @map("Supplier") @db.VarChar(100)
  expectedReceivedAt  DateTime?           @map("ExpectedReceivedAt")
  invoiceNumber       String?             @map("InvoiceNumber") @db.VarChar(100)
  supplierContactName String?             @map("SupplierContactName") @db.VarChar(100)
  supplierPhone       String?             @map("SupplierPhone") @db.VarChar(20)
  supplierEmail       String?             @map("SupplierEmail") @db.VarChar(100)
  status              String              @default("PENDING") @map("Status") @db.VarChar(20)
  notes               String?             @map("Notes") @db.VarChar(1000)
  orderedAt           DateTime            @default(now()) @map("OrderedAt")
  receivedAt          DateTime?           @map("ReceivedAt")
  createdBy           Int?                @map("CreatedBy")
  updatedAt           DateTime            @default(now()) @updatedAt @map("UpdatedAt")
  items               PurchaseOrderItem[]
  goodsReceipts       GoodsReceipt[]

  @@index([orderedAt], map: "IX_PurchaseOrders_OrderedAt")
  @@index([status], map: "IX_PurchaseOrders_Status")
  @@map("PurchaseOrders")
}

model PurchaseOrderItem {
  purchaseOrderItemId Int            @id @default(autoincrement()) @map("PurchaseOrderItemId")
  purchaseOrderId     Int            @map("PurchaseOrderId")
  variantId           Int            @map("VariantId")
  orderedQty          Int            @map("OrderedQty")
  receivedQty         Int            @default(0) @map("ReceivedQty")
  unitCost            Decimal        @map("UnitCost") @db.Decimal(18, 2)
  purchaseOrder       PurchaseOrder  @relation(fields: [purchaseOrderId], references: [purchaseOrderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_PurchaseOrderItems_PurchaseOrders")
  variant             ProductVariant @relation(fields: [variantId], references: [variantId], onDelete: NoAction, onUpdate: NoAction, map: "FK_PurchaseOrderItems_ProductVariants")
  goodsReceiptItems   GoodsReceiptItem[]

  @@unique([purchaseOrderId, variantId], map: "UQ_PurchaseOrderItems_Order_Variant")
  @@index([variantId], map: "IX_PurchaseOrderItems_VariantId")
  @@map("PurchaseOrderItems")
}

model Inventory {
  variantId          Int            @id @map("VariantId")
  availableQuantity  Int            @default(0) @map("AvailableQuantity")
  reservedQuantity   Int            @default(0) @map("ReservedQuantity")
  incomingQuantity   Int            @default(0) @map("IncomingQuantity")
  updatedAt          DateTime       @default(now()) @updatedAt @map("UpdatedAt")
  variant            ProductVariant @relation(fields: [variantId], references: [variantId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Inventory_ProductVariants")

  @@index([availableQuantity], map: "IX_Inventory_AvailableQuantity")
  @@map("Inventory")
}

model StockMovement {
  stockMovementId Int            @id @default(autoincrement()) @map("StockMovementId")
  variantId       Int            @map("VariantId")
  type            String         @map("Type") @db.VarChar(20)
  quantity        Int            @map("Quantity")
  referenceType   String?        @map("ReferenceType") @db.VarChar(30)
  referenceId     Int?           @map("ReferenceId")
  note            String?        @map("Note") @db.VarChar(500)
  createdBy       Int?           @map("CreatedBy")
  createdAt       DateTime       @default(now()) @map("CreatedAt")
  variant         ProductVariant @relation(fields: [variantId], references: [variantId], onDelete: Cascade, onUpdate: NoAction, map: "FK_StockMovements_ProductVariants")
  user            User?          @relation(fields: [createdBy], references: [userId], onDelete: SetNull, onUpdate: NoAction, map: "FK_StockMovements_Users")

  @@index([variantId, createdAt], map: "IX_StockMovements_Variant_CreatedAt")
  @@index([referenceType, referenceId], map: "IX_StockMovements_Reference")
  @@map("StockMovements")
}

model GoodsReceipt {
  goodsReceiptId  Int                @id @default(autoincrement()) @map("GoodsReceiptId")
  purchaseOrderId Int                @map("PurchaseOrderId")
  receiptNumber   String             @unique(map: "UQ_GoodsReceipts_ReceiptNumber") @map("ReceiptNumber") @db.VarChar(60)
  notes           String?            @map("Notes") @db.VarChar(1000)
  createdBy       Int?               @map("CreatedBy")
  createdAt       DateTime           @default(now()) @map("CreatedAt")
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [purchaseOrderId], onDelete: NoAction, onUpdate: NoAction, map: "FK_GoodsReceipts_PurchaseOrders")
  user            User?              @relation(fields: [createdBy], references: [userId], onDelete: SetNull, onUpdate: NoAction, map: "FK_GoodsReceipts_Users")
  items           GoodsReceiptItem[]

  @@index([purchaseOrderId, createdAt], map: "IX_GoodsReceipts_PurchaseOrder_CreatedAt")
  @@map("GoodsReceipts")
}

model GoodsReceiptItem {
  goodsReceiptItemId  Int               @id @default(autoincrement()) @map("GoodsReceiptItemId")
  goodsReceiptId      Int               @map("GoodsReceiptId")
  purchaseOrderItemId Int?              @map("PurchaseOrderItemId")
  variantId           Int               @map("VariantId")
  quantityReceived    Int               @map("QuantityReceived")
  unitCost            Decimal           @map("UnitCost") @db.Decimal(18, 2)
  goodsReceipt        GoodsReceipt      @relation(fields: [goodsReceiptId], references: [goodsReceiptId], onDelete: Cascade, onUpdate: NoAction, map: "FK_GoodsReceiptItems_GoodsReceipts")
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [purchaseOrderItemId], onDelete: SetNull, onUpdate: NoAction, map: "FK_GoodsReceiptItems_PurchaseOrderItems")
  variant             ProductVariant    @relation(fields: [variantId], references: [variantId], onDelete: NoAction, onUpdate: NoAction, map: "FK_GoodsReceiptItems_ProductVariants")

  @@index([goodsReceiptId], map: "IX_GoodsReceiptItems_GoodsReceiptId")
  @@index([variantId], map: "IX_GoodsReceiptItems_VariantId")
  @@map("GoodsReceiptItems")
}
